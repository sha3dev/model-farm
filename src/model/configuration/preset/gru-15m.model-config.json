      "timeToExpiryDistanceToStrike"
    ],
    "labelColumn": "targetUp"
  },
  "architecture": {
    "modelType": "gru",
    "recurrentLayerUnits": [64, 32],
    "denseHeadUnits": [24, 12],
    "layerCount": 2,
    "dropoutRate": 0.1,
    "recurrentDropoutRate": 0.04,
    "useBidirectional": false,
    "useBatchNormalization": false,
    "useLayerNormalization": false,
    "activation": "tanh",
    "recurrentActivation": "sigmoid",
    "outputActivation": "sigmoid",
    "kernelInitializer": "glorotUniform",
    "recurrentInitializer": "orthogonal",
    "useBias": true,
    "regularization": { "l1": 0, "l2": 0.00008, "maxNorm": 3 }
  },
  "training": {
    "optimizer": "adam",
    "learningRate": 0.001,
    "weightDecay": 0,
    "loss": "binaryCrossentropy",
    "metrics": ["accuracy"],
    "batchSize": 128,
    "maxEpochs": 4,
    "gradientClipNorm": 1,
    "labelSmoothing": 0,
    "mixedPrecision": false,
    "randomSeed": 42,
    "earlyStopping": { "isEnabled": true, "monitor": "accuracy", "mode": "maximize", "patienceEpochs": 2, "minDelta": 0.0005, "restoreBestWeights": true },
    "learningRateScheduler": { "type": "none", "factor": 0.5, "patienceEpochs": 7, "minLearningRate": 0.000001, "warmupEpochs": 2 },
    "checkpointing": {
      "isEnabled": true,
      "monitor": "accuracy",
      "mode": "maximize",
      "saveMode": "best",
      "directoryPath": "artifacts/checkpoints/polymarket-crypto-gru-15m-v1"
    }
  },
  "data": {
    "split": { "trainRatio": 0.7, "validationRatio": 0.15, "testRatio": 0.15 },
    "inputScaling": "standard",
    "targetScaling": "none",
    "missingValueStrategy": "forwardFill",
    "outlierStrategy": "clip",
    "outlierThreshold": 3,
    "shuffleTrainingWindows": false,
    "leakageGuards": { "enforceTemporalOrdering": true, "disallowFutureFeatures": true, "disallowGlobalFitOnValidationOrTest": true }
  },
  "search": { "isEnabled": false, "maxTrials": 40, "parallelTrials": 2, "objectiveMetric": "auc", "objectiveDirection": "maximize" },
  "inference": { "decisionThreshold": 0.5, "useMonteCarloDropout": false, "monteCarloSamples": 30, "calibrationWindowSize": 700 },
  "deployment": { "saveFormat": "tfjsLayers", "quantization": "none", "devicePreference": "auto" }
